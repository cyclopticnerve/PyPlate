{
    "PUB_META": {
        "META_SHORT_DESC": "A program for creating and building CLI/GUI/Package projects in Python from a template",
        "META_VERSION": "1.1.4",
        "META_KEYWORDS": [],
        "META_DEPS": {
            "Python 3.10+": "https://python.org"
        },
        "META_CATS": []
    },
    "PUB_BL": {
        "SKIP_ALL": [
            ".git",
            ".venv*",
            ".VSCodeCounter",
            "*.code-workspace",
            "dist",
            "docs",
            "i18n",
            "misc",
            "site",
            "todo",
            "LICENSE.txt",
            "requirements.txt",
            "**/__pycache__",
            "**/*.egg-info",
            "pyplate"
        ],
        "SKIP_CONTENTS": [
            "**/*.png",
            "**/*.jpg",
            "**/*.jpeg",
            "**/*.ico"
        ],
        "SKIP_HEADER": [],
        "SKIP_CODE": [
            "conf"
        ],
        "SKIP_TREE": [
            ".git",
            ".venv*",
            ".VSCodeCounter",
            "dist",
            "site",
            "**/__pycache__",
            "**/*.egg-info"
        ]
    },
    "PUB_ACT": {
        "ACT_VENV": true,
        "ACT_REQS": true,
        "ACT_GIT": true,
        "ACT_INST": true,
        "ACT_PURGE": true,
        "ACT_I18N": true,
        "ACT_META": true,
        "ACT_PLACE": true,
        "ACT_EDIT": true,
        "ACT_MAKE_DOCS": true,
        "ACT_TREE": true,
        "ACT_FREEZE": true,
        "ACT_BAKE_DOCS": true,
        "ACT_DEPLOY_DOCS": true,
        "ACT_COMPRESS": true,
        "ACT_REM_DIST": true
    },
    "PUB_DIST": {
        "bin": "assets",
        "conf": "assets",
        "i18n": "assets",
        "images": "assets",
        "install": "assets",
        "src": "assets",
        "requirements.txt": "assets/install"
    },
    "PUB_DOCS": {
        "DOCS_THEME": "",
        "DOCS_USE_RM": false,
        "DOCS_MAKE_API": true,
        "DOCS_DIR_API": [
            "src"
        ]
    },
    "PUB_I18N": {
        "DOMAIN": "pyplate",
        "SOURCES": [
            "bin",
            "install",
            "src",
            "develop.py"
        ],
        "CLANGS": {
            "Python": [
                ".py"
            ],
            "Glade": [
                ".ui",
                ".glade"
            ],
            "Desktop": [
                ".desktop"
            ]
        },
        "WLANGS": [
            "en"
        ],
        "CHARSET": "UTF-8"
    },
    "PUB_INST": {
        "INST_NAME": "PyPlate",
        "INST_VER": "1.1.4",
        "INST_DESK": false,
        "INST_CONT": {
            "bin/cli_debug": ".local/bin",
            "i18n": ".local/share/pyplate",
            "images": ".local/share/pyplate",
            "install": ".local/share/pyplate",
            "src": ".local/share/pyplate",
            "uninstall.py": ".local/share/pyplate"
        },
        "UNINST_CONT": [
            ".local/bin/pyplate",
            ".local/share/pyplate"
        ],
        "CFG_CONT": {
            "conf": ".config/pyplate"
        }
    }
}