[core]
	repositoryformatversion = 0
	filemode = true
	bare = false
	logallrefupdates = true
[remote "origin"]
	url = git@github.com:cyclopticnerve/PyPlate.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[pull]
	ff = only
[branch "main"]
	vscode-merge-base = origin/dev
	remote = origin
	merge = refs/heads/main
[branch "jsonc"]
	vscode-merge-base = origin/main
	remote = origin
	merge = refs/heads/jsonc
[branch "spinner"]
	vscode-merge-base = origin/main
	remote = origin
	merge = refs/heads/spinner
