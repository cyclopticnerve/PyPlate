{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "PM",
            "type": "debugpy",
            "request": "launch",
            "program": "PyPlate/src/pymaker.py",
            "console": "integratedTerminal",
            // run from above PyPlate project
            "cwd": "${workspaceFolder}/.."
        },
        {
            "name": "PM Debug",
            "type": "debugpy",
            "request": "launch",
            "program": "PyPlate/src/pymaker.py",
            "console": "integratedTerminal",
            // run from above PyPlate project
            "cwd": "${workspaceFolder}/..",
            "args": ["-d"]
        },
        {
            "name": "PB",
            "type": "debugpy",
            "request": "launch",
            "program": "PyPlate/src/pybaker.py",
            "console": "integratedTerminal",
            // run from above PyPlate project
            "cwd": "${workspaceFolder}/..",
            "args": [
                "-i"
            ]
        },
        {
            "name": "PB Debug",
            "type": "debugpy",
            "request": "launch",
            "program": "PyPlate/src/pybaker.py",
            "console": "integratedTerminal",
            // run from above PyPlate project
            "cwd": "${workspaceFolder}/..",
            "args": [
                "-d",
                "-i"
            ]
        },
        {
            "name": "PB Args",
            "type": "debugpy",
            "request": "launch",
            "program": "PyPlate/src/pybaker.py",
            "console": "integratedTerminal",
            // run from above PyPlate project
            "cwd": "${workspaceFolder}/..",
            "args": "${command:pickArgs}"
        },
        {
            "name": "Current",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Curr Args",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": "${command:pickArgs}"
        }
    ]
}
