{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Project",
            "type": "debugpy",
            "request": "launch",
            "program": "src/pyplate.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Prj Args",
            "type": "debugpy",
            "request": "launch",
            "program": "src/pyplate.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": "${command:pickArgs}"
        },
        {
            "name": "Current",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Curr Args",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": "${command:pickArgs}"
        }
    ]
}
// -)